# ── DATABASE ──────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# ── SUPABASE (optional — only if using Supabase) ──────────────────────
SUPABASE_URL=""
SUPABASE_ANON_KEY=""

# ── REDIS ─────────────────────────────────────────────────────────────
# Option A: Upstash (recommended for Railway/Vercel)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
# Option B: Standard Redis URL
# REDIS_URL="redis://localhost:6379"

# ── ANTHROPIC ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=""

# ── AUTH ──────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="generate-a-long-random-secret-here"
JWT_REFRESH_SECRET="generate-another-long-random-secret-here"
JWT_ACCESS_EXPIRES="15m"

# ── SPOTIFY ───────────────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""
SPOTIFY_REDIRECT_URI="http://localhost:3000/api/v1/integrations/spotify/callback"

# ── AWS S3 (for photo uploads) ────────────────────────────────────────
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET=""

# ── SERVER ────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"

# ── ADMIN ─────────────────────────────────────────────────────────────
ADMIN_SECRET="choose-a-strong-admin-password"
